# Optional explicit API base URL.
# If omitted, the app defaults to:
# - https://api.deymake.com/api/v1 on non-localhost hosts
# - http://127.0.0.1:8000/api/v1 on localhost/127.0.0.1
# VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_API_BASE_URL=https://api.deymake.com/api/v1

# OAuth is handled by the backend redirect/callback routes.
# Do not place Google/Facebook client secrets in this frontend env file.


# Vite dev proxy target for /api requests during local development.
# VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:8000
# VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:8000
VITE_BACKEND_PROXY_TARGET=https://api.deymake.com/api/v1